"Refract"
{
	"%keywords" "tf"
	"$refractamount" ".03"
	//"$refracttint" "{225 225 210}"
	"$refracttint" "{204 197 182}"
	"$refractblur" "1"
	"$bluramount" "2"
	"$ignorez" "1"

	"$scale" "[1 1]"

	"$bumpmap" "dev/water_dudv"
	//"$normalmap" "water/tfwater001_normal"
	"$normalmap" "liquidpack/water/water_sea"
	"$bumpframe" "0"


	"Proxies"
	{
		"AnimatedTexture"
		{
			"animatedtexturevar" "$normalmap"
			"animatedtextureframenumvar" "$bumpframe"
			"animatedtextureframerate" 30.00
		}
		"TextureScroll"
		{
			"texturescrollvar" "$bumptransform"
			"texturescrollrate" .1
			"texturescrollangle" 45.00
		}
	}
}
