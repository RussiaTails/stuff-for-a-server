"Spritecard"
{
	"srgb?$overbrightfactor" "5"
	"$basetexture" "particle/flameThrowerFire/flamethrowerfire102"
	$translucent 1
//	"$overbrightfactor" "31"
	"$addself" "0.5"
	$DEPTHBLEND "1"    
	$DEPTHBLENDSCALE "100"
	$startfadesize "1.2"
	$endfadesize "2.0"
	$maxsize "1.6"
	<dx90
	{   
		// help fill rate on low end
		$maxsize ".15"
	}
}