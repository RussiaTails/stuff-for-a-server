"VertexLitGeneric"
{
	"$basetexture" "Deadnaut/Construction/Chest_done"
	"$basemapalphaphongmask" "1"
	
	"$phong" "1"
	"$phongboost" "4"
	"$phongexponent" "10"	
	"$phongfresnelranges"	"[.5 .7 1]"
	"$halflambert" "0"
//	"$phongexponenttexture" "Deadnaut/Normal/Chest_exp"

	"$lightwarptexture" "models/lightwarps/robot_lightwarp"

	
	"$rimlight" "1"						
	"$rimlightexponent" "0.5"				
	"$rimlightboost" "0.75"
	"$rimmask" "1"

	"$detail" "effects/tiledfire/fireLayeredSlowTiled512.vtf"	
	"$detailscale" "5"
	"$detailblendfactor" .01
	"$detailblendmode" 6

	"$yellow" "0"
	"$one" "1"

	// Cloaking
	"$cloakPassEnabled" "1"

	"Proxies"
	{
		"spy_invis"
		{
		}
		"AnimatedTexture"
		{
			"animatedtexturevar" "$detail"
			"animatedtextureframenumvar" "$detailframe"
			"animatedtextureframerate" 30
		}
		"BurnLevel"
		{
			"resultVar" "$detailblendfactor"
		}
		"YellowLevel"
		{
			"resultVar" "$yellow"
		}
		"Equals"
		{
			"srcVar1"  "$yellow"
			"resultVar" "$color2"
		}

	}
}



