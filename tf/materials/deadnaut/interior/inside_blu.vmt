"VertexLitGeneric"
{
	"$basetexture" "Deadnaut/Interior/inside_blu"
	"$BasemapAlphaPhongMask" "1"
	"$selfillum" "1"
	"$selfillummask" "Deadnaut/Interior/si"
	
	"$phong" "1"
	"$phongboost" "10"
	"$phongexponent" "25"	
	"$phongfresnelranges"	"[.5 1.7 10]"
	"$halflambert" "0"

	"$lightwarptexture" "models/buildables/sentry1/Sentry1_lightwarp"

	
	"$rimlight" "1"						
	"$rimlightexponent" "1"				
	"$rimlightboost" "2"
	"$rimmask" "1"

	"$detail" "effects/tiledfire/fireLayeredSlowTiled512.vtf"	
	"$detailscale" "5"
	"$detailblendfactor" .01
	"$detailblendmode" 6

	"$yellow" "0"
	"$one" "1"

	// Cloaking
	"$cloakPassEnabled" "1"

	"Proxies"
	{
		"spy_invis"
		{
		}
		"AnimatedTexture"
		{
			"animatedtexturevar" "$detail"
			"animatedtextureframenumvar" "$detailframe"
			"animatedtextureframerate" 30
		}
		"BurnLevel"
		{
			"resultVar" "$detailblendfactor"
		}
		"YellowLevel"
		{
			"resultVar" "$yellow"
		}
		"Equals"
		{
			"srcVar1"  "$yellow"
			"resultVar" "$color2"
		}

	}
}
