"VertexlitGeneric"
{
	"$basetexture" "models/weapons/c_items/c_darksoul"
	"$bumpmap" "models/weapons/c_items/c_darksoul_normal"
	"$phong" "1"
	"$selfillum" "1"
	"$selfillummask" "models/weapons/c_items/c_darksoul_light"
	"$cloakPassEnabled" "1"
	"Proxies"
	{
		"vm_invis"
		{
		}
		"ModelGlowColor"
		{
			"resultVar" "$glowcolor"
		}
		"Equals"
		{
			"srcVar1"  "$glowcolor"
			"resultVar" "$selfillumtint"
		}
		"Equals"
		{
			"srcVar1"  "$glowcolor"
			"resultVar" "$color2"
		}
	}
}
