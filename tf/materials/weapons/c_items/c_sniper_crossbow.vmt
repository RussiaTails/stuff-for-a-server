"VertexlitGeneric"
{
	"$baseTexture" "models/weapons/c_items/c_sniper_crossbow"

	"$phong" "1"
	"$phongexponent" "25"
	"$phongboost" "15"	
	"$lightwarptexture" "models/lightwarps/weapon_lightwarp"

	"$phongfresnelranges" "[0.25 0.5 1]"

	"$basemapalphaphongmask" "1"

	"$rimlight" "1"
	"$rimlightexponent" "15"	
	"$rimlightboost" "0.2"

	"$glowcolor" "1"

	// Cloaking
	"$cloakPassEnabled" "1"
	"Proxies"
	{
		"vm_invis"
		{
		}
		"ModelGlowColor"
		{
			"resultVar" "$glowcolor"
		}
		"Equals"
		{
			"srcVar1"  "$glowcolor"
			"resultVar" "$selfillumtint"
		}
		"Equals"
		{
			"srcVar1"  "$glowcolor"
			"resultVar" "$color2"
		}
	}
}
