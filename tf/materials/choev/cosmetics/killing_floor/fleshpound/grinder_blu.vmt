VertexLitGeneric
{
//Main
	$basetexture					"ChoEv/Cosmetics/Killing_Floor/Fleshpound/Grinder_BLU_D"
	$bumpmap						"ChoEv/Cosmetics/Killing_Floor/Fleshpound/Grinder_N"

//Other
	$lightwarptexture				"models/lightwarps/weapon_lightwarp"
	$halflambert					"1"
	$normalmapalphaphongmask		"1"

//Phong
	$phong							"1"
	$phongexponent					"25"
	$phongboost						"1.5"
	$phongfresnelranges				"[0.22 0.86 20]"
	$basemapalphaphongmask			"1"

//Self Illumination
	$selfillum						"1"
	$selfillummask					"ChoEv/Cosmetics/Killing_Floor/Fleshpound/Grinder_SI"

//Rimlight
	$rimlight						"1"
	$rimlightexponent				"4"
	$rimlightboost					"2"

//Cloaking
	$cloakPassEnabled				"1"
	$sheenPassEnabled				"1"

	$sheenmap						"cubemaps/cubemap_sheen001"
	$sheenmapmask					"Effects/AnimatedSheen/animatedsheen0"
	$sheenmaptint					"[ 1 1 1 ]"
	$sheenmapmaskframe				"0"
	$sheenindex						"0"

	$yellow							"0"

	"Proxies"
	{
		"AnimatedWeaponSheen"
		{
			"animatedtexturevar"			"$sheenmapmask"
			"animatedtextureframenumvar" 	"$sheenmapmaskframe"
			"animatedtextureframerate" 		"40"
		}
		"invis"
		{
		}
		"ModelGlowColor"
		{
			"resultVar" "$glowcolor"
		}
		"Equals"
		{
			"srcVar1"  "$glowcolor"
			"resultVar" "$selfillumtint"
		}
		"Equals"
		{
			"srcVar1"  "$glowcolor"
			"resultVar" "$color2"
		}
		"YellowLevel"
		{
			"resultVar" "$yellow"
		}
		"Multiply"
		{
			"srcVar1" "$color2"
			"srcVar2" "$yellow"
			"resultVar" "$color2"
		}
	
	
		"WeaponSkin" {
		}
	}
}