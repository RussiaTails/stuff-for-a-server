"VertexlitGeneric"
{
	"$baseTexture" "models/conceptflaregun/conceptflaregunstockless"

//	"$envmap" "env_cubemap"
//	"$envmaptint" "[.15 .15 .15]"
//	"$basemapenvmapmask" "1"

	"$phong" "1"
	"$phongexponent" "120"
	"$phongboost" "1"	
	"$lightwarptexture" "models/lightwarps/weapon_lightwarp"
	"$phongfresnelranges" "[0.45 0.7 1]"
	"$basemapalphaphongmask" "1"

	"$rimlight" "1"
	"$rimlightexponent" "10"	
	"$rimlightboost" "0.5"


	"$glowcolor" "1"

	// Cloaking
	"$cloakPassEnabled" "1"
	"Proxies"
	{
		"weapon_invis"
		{
		}
		"ModelGlowColor"
		{
			"resultVar" "$glowcolor"
		}
		"Equals"
		{
			"srcVar1"  "$glowcolor"
			"resultVar" "$selfillumtint"
		}
		"Equals"
		{
			"srcVar1"  "$glowcolor"
			"resultVar" "$color2"
		}
	}
}
