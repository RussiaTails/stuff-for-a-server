VertexLitGeneric
{
	$basetexture "models/puppet/player/spy/ch_spy_marionette_blu.vtf"

	$phong 1
	$phongexponent 5
	$phongboost 1.0
	$phongfresnelranges "[0.25 0.75 1]"
	//$phongtint "{255 128 64}"

	$rimlight 1
	$rimlightexponent 4
	$rimlightboost 2

	$lightwarptexture "models/player/pyro/pyro_lightwarp.vtf"

	$BaseMapAlphaPhongMask 1

	// Cloaking
	$cloakPassEnabled 1

	$detail "effects/tiledfire/fireLayeredSlowTiled512.vtf"	
	$detailscale 5
	$detailblendfactor .01
	$detailblendmode 6

	$yellow 0
	$one 1

	Proxies
	{
		"spy_invis"
		{
		}
		"AnimatedTexture"
		{
			"animatedtexturevar" "$detail"
			"animatedtextureframenumvar" "$detailframe"
			"animatedtextureframerate" 30
		}
		"BurnLevel"
		{
			"resultVar" "$detailblendfactor"
		}
		"YellowLevel"
		{
			"resultVar" "$yellow"
		}
		"Equals"
		{
			"srcVar1" "$yellow"
			"resultVar" "$color2"
		}
	}
}