"VertexLitGeneric"
{
	"$baseTexture" "models/workshop/weapons/c_models/c_catheter/c_catheter_main"
	"$bumpmap" "models/workshop/weapons/c_models/c_catheter/c_catheter_main_normal"
	
//	"$envmapmaskbasealpha" "1"
//	"$envmap" env_cubemap
//	"$envmaptint" "[.05 0.05 0.05]"
	


	"$phong" "1"
	"$phongexponent" "10"
	"$phongboost" "25"	

//	"$lightwarptexture" "models/player/pyro/pyro_lightwarp"
	"$lightwarptexture" "models/lightwarps/weapon_lightwarp"

	"$phongfresnelranges"	"[.25 .5 1]"
	"$halflambert" "1"

	// Rim lighting parameters
	"$rimlight" "1"												// To enable rim lighting (requires phong)
	"$rimlightexponent" "4"										// Exponent for phong component of rim lighting	
	"$rimlightboost" ".25"										// Boost for ambient cube component of rim lighting
//	"$rimmask" "1"

	"360?$color2" "[ 0.5 0.5 0.5 ]"

	"$glowcolor" "1"

	// Cloaking
	"$cloakPassEnabled" "1"

	"$yellow" "0"

	"Proxies"
	{
		"AnimatedWeaponSheen"
		{
			"animatedtexturevar" 		"$sheenmapmask"
			"animatedtextureframenumvar" 	"$sheenmapmaskframe"
			"animatedtextureframerate" 		"40"
		}
		"invis"
		{
		}
		"ModelGlowColor"
		{
			"resultVar" "$glowcolor"
		}
		"Equals"
		{
			"srcVar1"  "$glowcolor"
			"resultVar" "$selfillumtint"
		}
		"Equals"
		{
			"srcVar1"  "$glowcolor"
			"resultVar" "$color2"
		}
		"YellowLevel"
		{
			"resultVar" "$yellow"
		}
		"Multiply"
		{
			"srcVar1" "$color2"
			"srcVar2" "$yellow"
			"resultVar" "$color2"
		}
	}
}
