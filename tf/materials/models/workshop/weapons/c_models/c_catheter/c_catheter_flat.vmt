"VertexLitGeneric"
{
	"$baseTexture" "models/workshop/weapons/c_models/c_catheter/c_catheter_main"
	"$bumpmap" "models/workshop/weapons/c_models/c_catheter/c_catheter_main_normal"
	

	"$phong" "1"
	"$phongexponent" "5"
	"$phongboost" "3"	

	"$lightwarptexture" "models/player/pyro/pyro_lightwarp"
//	"$lightwarptexture" "models/lightwarps/weapon_lightwarp"

	"$phongfresnelranges"	"[.25 .5 1]"
	"$halflambert" "1"



	// Rim lighting parameters
//	"$rimlight" "1"			
//	"$rimlightexponent" "4"	
//	"$rimlightboost" "1"
//	"$rimmask" "1"

	"360?$color2" "[ 0.5 0.5 0.5 ]"

	"$glowcolor" "1"

	// Cloaking
	"$cloakPassEnabled" "1"

	"$yellow" "0"

	"Proxies"
	{
		"AnimatedWeaponSheen"
		{
			"animatedtexturevar" 		"$sheenmapmask"
			"animatedtextureframenumvar" 	"$sheenmapmaskframe"
			"animatedtextureframerate" 		"40"
		}
		"invis"
		{
		}
		"ModelGlowColor"
		{
			"resultVar" "$glowcolor"
		}
		"Equals"
		{
			"srcVar1"  "$glowcolor"
			"resultVar" "$selfillumtint"
		}
		"Equals"
		{
			"srcVar1"  "$glowcolor"
			"resultVar" "$color2"
		}
		"YellowLevel"
		{
			"resultVar" "$yellow"
		}
		"Multiply"
		{
			"srcVar1" "$color2"
			"srcVar2" "$yellow"
			"resultVar" "$color2"
		}
	}
}
