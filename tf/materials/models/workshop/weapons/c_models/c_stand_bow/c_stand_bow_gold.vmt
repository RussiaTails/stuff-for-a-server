"VertexlitGeneric"
{
  "$baseTexture" "models/workshop/weapons/c_models/c_stand_bow/c_stand_bow"
  "$lightwarptexture" "models/lightwarps/softened_weapon_lightwarp"
  
  //"$envmap" "effects/saxxy_gold"
  "$envmap" "cubemaps/cubemap_gold001"
  //"$envmap" "env_cubemap"
  "$envmaptint" "[.5 .4 .3]"
  //"$envmap" "effects/goldcube"
	//"$envmaptint" "[.6 .4 .3]"

	"$phong" "1"
	"$basemapalphaphongmask" "1"
  "$phongexponent" "10"
  //"$phongexponenttexture" "models/workshop/weapons/c_models/c_stand_bow/c_stand_bow_phongexp"
	"$phongboost" "20"
  "$phongtint" "[1 .68 .28]"
	"$phongfresnelranges"	"[.25 .5 1]"

	"$rimlight" "1"
	"$rimlightexponent" "4"	
	"$rimlightboost" "1"
  
	"$glowcolor" "1"

	// Cloaking
	"$cloakPassEnabled" "1"
	"$sheenPassEnabled" "1"

	"$sheenmap" 		"cubemaps/cubemap_sheen001"
	"$sheenmapmask" 		"Effects/AnimatedSheen/animatedsheen0"
	"$sheenmaptint" 		"[ 1 1 1 ]"
	"$sheenmapmaskframe" 	"0"
	"$sheenindex" 		"0"

	"$yellow" "0"

	"Proxies"
	{
		"AnimatedWeaponSheen"
		{
			"animatedtexturevar" 		"$sheenmapmask"
			"animatedtextureframenumvar" 	"$sheenmapmaskframe"
			"animatedtextureframerate" 		"40"
		}
		"invis"
		{
		}
		"ModelGlowColor"
		{
			"resultVar" "$glowcolor"
		}
		"Equals"
		{
			"srcVar1"  "$glowcolor"
			"resultVar" "$selfillumtint"
		}
		"Equals"
		{
			"srcVar1"  "$glowcolor"
			"resultVar" "$color2"
		}
		"YellowLevel"
		{
			"resultVar" "$yellow"
		}
		"Multiply"
		{
			"srcVar1" "$color2"
			"srcVar2" "$yellow"
			"resultVar" "$color2"
		}
	}
}
