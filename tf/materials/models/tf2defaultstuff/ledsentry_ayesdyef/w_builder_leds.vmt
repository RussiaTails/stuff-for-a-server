"VertexLitGeneric"
{
	"$baseTexture" "models/tf2defaultstuff/ledsentry_ayesdyef/w_builder_leds"
	"$bumpmap" "models/tf2defaultstuff/normal"

	"$nocull" "1"

	"$phong" "1"
	"$phongexponent" "50"
	"$phongboost" "4"	
	"$lightwarptexture" "models/tf2defaultstuff/weapon_lightwarp"
	"$phongfresnelranges" "[0.25 0.5 1]"
	"$basemapalphaphongmask" "1"

	"$rimlight" "1"
	"$rimlightexponent" "4"	
	"$rimlightboost" "2"

	// Cloaking
	"$cloakPassEnabled" "1"
	"$sheenPassEnabled" "1"

	"$sheenmap" "cubemaps/cubemap_sheen001"
	"$sheenmapmask" "effects/animatedsheen/animatedsheen0"
	"$sheenmaptint" 		"[ 1 1 1 ]"
	"$sheenmapmaskframe" 	"0"
	"$sheenindex" 		"0"

	"$yellow" "0"

	"Proxies"
	{
		"AnimatedWeaponSheen"
		{
			"animatedtexturevar" 		"$sheenmapmask"
			"animatedtextureframenumvar" 	"$sheenmapmaskframe"
			"animatedtextureframerate" 		"40"
		}
		"invis"
		{
		}
		"YellowLevel"
		{
			"resultVar" "$yellow"
		}
		"Equals"
		{
			"srcVar1"  "$yellow"
			"resultVar" "$color2"
		}
	}

}