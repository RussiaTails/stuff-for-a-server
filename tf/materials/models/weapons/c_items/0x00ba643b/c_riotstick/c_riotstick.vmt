"VertexlitGeneric"
{
	"$baseTexture" "models/weapons/c_items/0x00ba643b/c_riotstick/c_riotstick"

	"$phong" "1"
	"$phongexponent" "10"
	"$phongboost" "1"

	"$lightwarptexture" "models/lightwarps/weapon_lightwarp"

//	"$phongfresnelranges"	"[.6 1 1.5]"
	"$phongfresnelranges"	"[.25 .5 1]"
	"$basemapalphaphongmask" "1"

	"$rimlight" "1"
	"$rimlightexponent" "3"
	"$rimlightboost" "4"

	"$glowcolor" "1"

	"$cloakPassEnabled" "1"

	"Proxies"
	{
		"weapon_invis"
		{
		}
		"ModelGlowColor"
		{
			"resultVar" "$glowcolor"
		}
		"Equals"
		{
			"srcVar1"  "$glowcolor"
			"resultVar" "$selfillumtint"
		}
		"Equals"
		{
			"srcVar1"  "$glowcolor"
			"resultVar" "$color2"
		}
	}
}
