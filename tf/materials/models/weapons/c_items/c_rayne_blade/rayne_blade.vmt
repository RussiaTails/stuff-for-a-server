"VertexlitGeneric"
{
//Main
	"$basetexture" "models/weapons/c_items/c_rayne_blade/rayne_blade_d"
	"$bumpmap" "models/weapons/c_items/c_rayne_blade/rayne_blade_n"

//Other
	"$halflambert"					"1"
	"$lightwarptexture" "models/lightwarps/weapon_lightwarp"
	"$glowcolor"					"1"

//Envmap
	"$envmap" "cubemaps/cubemap_sheen001" 
	"$envmaptint"					"[.5 .5 .5]"
	"$normalmapalphaenvmapmask"		"1"

//Phong
	"$phong"						"1"
	"$phongexponent"				"5"
	"$phongboost"					"10"
	"$phongfresnelranges"			"[.25 .5 1]"
	"$basemapalphaphongmask"		"1"
	"$basephongexponent"			"15"
	"$basephongboost"				"55"

//Rimlight
	"$rimlight"						"1"
	"$rimlightexponent"				"10"
	"$rimlightboost"				"1"

//Cloaking
	"$cloakPassEnabled"				"1"
	"$sheenPassEnabled"				"1"

	"$sheenmap" "cubemaps/cubemap_sheen001"
	"$sheenmapmask" "effects/animatedsheen/animatedsheen0"
	"$sheenmaptint" 				"[ 1 1 1 ]"
	"$sheenmapmaskframe" 			"0"
	"$sheenindex" 					"0"

	"$yellow"						"0"

	"Proxies"
	{
		"AnimatedWeaponSheen"
		{
			"animatedtexturevar" 		"$sheenmapmask"
			"animatedtextureframenumvar" 	"$sheenmapmaskframe"
			"animatedtextureframerate" 		"40"
		}
		"invis"
		{
		}
		"ModelGlowColor"
		{
			"resultVar" "$glowcolor"
		}
		"Equals"
		{
			"srcVar1"  "$glowcolor"
			"resultVar" "$selfillumtint"
		}
		"Equals"
		{
			"srcVar1"  "$glowcolor"
			"resultVar" "$color2"
		}
		"YellowLevel"
		{
			"resultVar" "$yellow"
		}
		"Multiply"
		{
			"srcVar1" "$color2"
			"srcVar2" "$yellow"
			"resultVar" "$color2"
		}
	}
}