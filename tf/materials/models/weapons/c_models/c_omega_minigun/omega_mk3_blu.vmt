"VertexLitGeneric"
{
//Main
	$basetexture					"models/weapons/c_models/c_omega_minigun/Omega_Mk3_BLU_D"
	$bumpmap						"models/weapons/c_models/c_omega_minigun/Omega_Mk3_N"

//Other
	"$halflambert"					"1"
	"$lightwarptexture" "models/lightwarps/weapon_lightwarp"
	"$glowcolor"					"1"

//Phong
	"$phong"						"1"
	"$phongboost"					"0.15"
	"$phongexponent"				"25"
	"$phongfresnelranges"			"[.5 1.5 10]"

//Rimlight
	"$rimlight"						"1"		
	"$rimlightexponent"				"4"	
	"$rimlightboost"				"1.5"

//Self Illumination
	"$selfillum"					"1"
	"$selfillummask" "models/weapons/c_models/c_omega_minigun/omega_mk3_si"

//Cloaking
	"$cloakPassEnabled"				"1"
	"$sheenPassEnabled"				"1"

	"$sheenmap" "cubemaps/cubemap_sheen001"
	"$sheenmapmask" "effects/animatedsheen/animatedsheen0"
	"$sheenmaptint" 				"[ 1 1 1 ]"
	"$sheenmapmaskframe" 			"0"
	"$sheenindex" 					"0"

	"$yellow"						"0"

	"Proxies"
	{
		"AnimatedWeaponSheen"
		{
			"animatedtexturevar" 		"$sheenmapmask"
			"animatedtextureframenumvar" 	"$sheenmapmaskframe"
			"animatedtextureframerate" 		"40"
		}
		"invis"
		{
		}
		"ModelGlowColor"
		{
			"resultVar" "$glowcolor"
		}
		"Equals"
		{
			"srcVar1"  "$glowcolor"
			"resultVar" "$selfillumtint"
		}
		"Equals"
		{
			"srcVar1"  "$glowcolor"
			"resultVar" "$color2"
		}
		"YellowLevel"
		{
			"resultVar" "$yellow"
		}
		"Multiply"
		{
			"srcVar1" "$color2"
			"srcVar2" "$yellow"
			"resultVar" "$color2"
		}
	}
}