"VertexLitGeneric"
{
	"$basetexture" "models/jcthornton/tongueteeth2"
	"$bumpmap" "models/jcthornton/tongueteeth_normal"
	"$phong" "1"
	"$PhongAlbedoTint"	"1"
//	"$phongexponent" "21"
