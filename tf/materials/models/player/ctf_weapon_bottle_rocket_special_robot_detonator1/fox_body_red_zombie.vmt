"VertexLitGeneric"
{
	"$basetexture" "models/player/scout_fox_2014/fox_body_red_zombie"
	"$bumpmap" "models/player/scout_fox_2014/fox_body_normal"
	"$detail" "effects/tiledfire/fireLayeredSlowTiled512.vtf"	
	"$detailscale" "5"
	"$detailblendfactor" .01
	"$detailblendmode" 6

	"$alphatest" "0"

	"$yellow" "0"
	"$one" "1"

	"$phong" "1"
	"$phongexponent" "20"
	"$phongboost" "0"	
	"$lightwarptexture" "models/player/pyro/pyro_lightwarp"
	"$phongfresnelranges"	"[.3 1 8]"
	"$halflambert" "0"

	"$rimlight" "1"
	"$rimlightexponent" "15"
	"$rimlightboost" ".25"

	"$cloakPassEnabled" "1"
	"Proxies"
	{
		"spy_invis"
		{
		}
		"AnimatedTexture"
		{
			"animatedtexturevar" "$detail"
			"animatedtextureframenumvar" "$detailframe"
			"animatedtextureframerate" 30
		}
		"BurnLevel"
		{
			"resultVar" "$detailblendfactor"
		}
		"YellowLevel"
		{
			"resultVar" "$yellow"
		}
		"Equals"
		{
			"srcVar1" "$yellow"
			"resultVar" "$color2"
		}
	}
}