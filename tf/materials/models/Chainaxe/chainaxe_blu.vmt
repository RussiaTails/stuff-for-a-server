"VertexLitGeneric"
{
	"$basetexture"	"models/Chainaxe/chainaxe_blu"
	"$bumpMap" "models/Chainaxe/chainaxe_normal"

	"$phong" "1"
	"$phongexponent" "25"
	"$phongboost" "3"	
	"$lightwarptexture" "models/lightwarps/weapon_lightwarp"
	"$phongfresnelranges"	"[.25 .5 1]"

	"$rimlight" "1"
	"$rimlightexponent" "4"	
	"$rimlightboost" "1"

	"360?$color2" "[ 0.9 0.8 0.8 ]"

$color2 "[1 1 1]"
$ambientocclusion 1
$detail "models/Chainaxe/chainaxe_blu_blend"
$detailscale 1
$detailblendfactor "1"
$detailblendmode 5

	"$glowcolor" "1"

	// Cloaking
	"$cloakPassEnabled" "1"
	"Proxies"
	{
		"weapon_invis"
		{
		}
		"ModelGlowColor"
		{
			"resultVar" "$glowcolor"
		}
		"Equals"
		{
			"srcVar1"  "$glowcolor"
			"resultVar" "$selfillumtint"
		}
		"Equals"
		{
			"srcVar1"  "$glowcolor"
			"resultVar" "$color2"
		}
	}
}
