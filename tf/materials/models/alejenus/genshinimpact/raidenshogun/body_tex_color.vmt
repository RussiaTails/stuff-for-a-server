"VertexLitGeneric"
{

	"$basetexture" "models/alejenus/genshinimpact/raidenshogun/body_tex_color"
	"$lightwarptexture" "models/alejenus/genshinimpact/raidenshogun/warp"
	"$halflambert" "1"
	"$nocull" "0"

	$phong 1
	$phongalbedotint 1
    $phongtint "[ 1 1 1]"
	$phongexponent 10
	$phongboost 0.0001
	$phongalbedoboost 4
	$phongfresnelranges "[0.1 0.2 0.5]"
	$rimlight 1
	$rimlightexponent 15
	$rimlightboost 0.5
	$rimlightmask 1
	
	$blendtintbybasealpha "1" // alpha channel of $basetexture: color mask.
 	$blendtintcoloroverbase "0" // blend mode. anything =/= 0 is ugly!IF UC
	
	Proxies
	{
		PlayerColor

		{
			resultVar	$color2
		}
	}
}


