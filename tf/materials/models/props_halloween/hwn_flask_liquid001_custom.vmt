"VertexLitGeneric"
{
	"$basetexture" "models/props_halloween/flask_liquid"
	
	"$phong" "1"
	"$phongexponent" "15"
	"$phongboost" "5"	
	"$lightwarptexture" "models/player/pyro/pyro_lightwarp"	
	"$phongfresnelranges"	"[1.5 .5 3]"

	"$colortint_base" "{242 17 28}"
	"$colortint_tmp" "[0 0 0]" 
	"$color2" "[255 255 255]"

	"$selfillum" "1"
	
	"$rimlight" "1"						
	"$rimlightexponent" "4"				
	"$rimlightboost" "2"

	"$mult" "65025"
	"$rngX" "0"
	"$rngY" "0"
	"$rngZ" "0"

	// Cloaking
	"$cloakPassEnabled" "1"
	"proxies"
	{
		"EntityRandom"
		{
			"resultVar" "$rngX"
			"scale"		"65025"
		}
		"Multiply"
		{
			"srcVar1" "$rngX"
			"srcVar2" "$mult"
			"resultVar" "$rngY"
		}
		"Multiply"
		{
			"srcVar1" "$rngY"
			"srcVar2" "$mult"
			"resultVar" "$rngZ"
		}
		"Sine"
		{
			"resultVar"	"$colortint_base[0]"
			"timeoffset"	"$rngX"
			"sineperiod"	"99999"
			"sinemin"		"0"
			"sinemax"		"1"
		}
		"Sine"
		{
			"resultVar"	"$colortint_base[1]"
			"timeoffset"	"$rngY"
			"sineperiod"	"99999"
			"sinemin"		"0"
			"sinemax"		"1"
		}
		"Sine"
		{
			"resultVar"	"$colortint_base[2]"
			"timeoffset"	"$rngZ"
			"sineperiod"	"99999"
			"sinemin"		"0"
			"sinemax"		"1"
		}
		"invis"
		{
		}
		"ItemTintColor"
		{
			"resultVar"		"$colortint_tmp"
		}
		"SelectFirstIfNonZero"
		{
			"srcVar1"		"$colortint_tmp"
			"srcVar2"		"$colortint_base"
			"resultVar"		"$color2"
		}
	}
}
